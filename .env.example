# ============================================================
#  Credenciales del portal Growatt OSS (oss.growatt.com)
# ============================================================
# Usuario de operador/distribuidor con acceso a la planta POLLO COA.
GROWATT_USER=AZPA4001
GROWATT_PASSWORD=changeme

# ============================================================
#  Base de datos
# ============================================================
# SQLite local (dev). Para producción usar Postgres, p.ej:
#   DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/growatt
DATABASE_URL=sqlite:///growatt_test.db

# ============================================================
#  API REST
# ============================================================
# Clave que el cliente debe enviar en la cabecera X-API-Key.
API_KEY=PRUEBAS_GROWATT_INVERSORES
API_HOST=127.0.0.1
API_PORT=8001

# ============================================================
#  Scraper / Playwright
# ============================================================
# true = navegador sin ventana (producción). false = ver el navegador (debug).
HEADLESS=true
# Timeout por navegación/llamada (ms)
NAV_TIMEOUT_MS=60000
